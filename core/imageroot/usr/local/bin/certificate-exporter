import os
import glob
import time
import json
import agent
import os.path
import logging
import hashlib
from watchdog.observers import Observer
from watchdog.events import FileSystemEventHandler

def _read_and_set(path):
    rdb = agent.redis_connect(privileged = True)
    with open(path) as fp:
        try:
            data = json.load(fp)
        except:
            return
        logging.debug(data)
        for info in data["letsencrypt"]["Certificates"]:
            rkey = f'certificate/{info["domain"]["main"]}'
            cur_cert = rdb.hget(rkey, 'cert')
            cur_key = rdb.hget(rkey, 'key')
            if not cur_cert or cur_cert != info["certificate"]:
                logging.info(f'Saving certificate inside {rkey}.cert')
                rdb.hset(rkey, "cert", info["certificate"])

            if not cur_key or cur_key != info["key"]:
                logging.info(f'Saving key inside" {rkey}.key"')
                rdb.hset(rkey, "key",  info["key"])
    rdb.close()

class CertificateHandler(FileSystemEventHandler):
    def on_modified(self,  event):
        logging.debug(f'event type: {event.event_type} path : {event.src_path}')
        if not os.path.isfile(event.src_path):
            return
        _read_and_set(event.src_path)

# Setup global vars
observer = Observer()

# Setuop logging level from environment variable
loglevel = os.getenv("LOG", "WARNING")
numeric_level = getattr(logging, loglevel.upper(), None)
if not isinstance(numeric_level, int):
    loglevel = logging.WARNING
logging.basicConfig(format='%(levelname)s:%(message)s', level=numeric_level)

# Search for all traefik certificate storage files
for f in glob.glob('/home/traefik?/.local/share/containers/storage/volumes/traefik-acme/_data/acme.json'):
    event_handler = CertificateHandler()
    logging.info(f'Watching {f}')
    observer.schedule(event_handler, path=f, recursive=False)
    # Make sure Redis is updated on service start
    _read_and_set(f)

observer.start()

try:
   while  True:
        time.sleep(1)
finally:
    observer.stop()
    observer.join()
